    "axios": "^1.4.0",
    "date-fns": "^2.29.0",
    "lucide-react": "^1.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.0",
    "recharts": "^2.7.0",
    "redux": "^4.2.0",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
