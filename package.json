{
  "name": "coordinadora-dashboard",
  "type": "module",
  "version": "1.0.0",
  "description": "Real-time operational dashboard for Coordinadora incident management",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
